{
  "name": "recipe-book",
  "version": "0.1.0-alpha.0",
  "license": "MIT",
  "private": true,
  "description": "A full-stack web application for managing recipes and ingredients.",
  "author": {
    "name": "Brittni Watkins",
    "url": "https://blwatkins.github.io/"
  },
  "homepage": "https://github.com/blwatkins/recipe-book#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blwatkins/recipe-book.git"
  },
  "bugs": {
    "url": "https://github.com/blwatkins/recipe-book/issues"
  },
  "type": "module",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "main": "src/main.mjs",
  "scripts": {
    "lint:client": "eslint -c eslint.config.client.mjs ./src-client ./src-shared",
    "lint:server": "eslint -c eslint.config.server.mjs .",
    "lint:all": "npm run lint:client && npm run lint:server",
    "build": "webpack --mode=production",
    "build:dev": "webpack --mode=development",
    "build:check": "npm run build:dev && npm run build",
    "build:watch": "webpack --mode=production --watch",
    "build:watch:dev": "webpack --mode=development --watch",
    "test": "echo \"Error: no test specified\" && exit 1",
    "serve": "dotenvx run -f .env.prod -- nodemon src/main.mjs",
    "serve:dev": "dotenvx run -- nodemon src/main.mjs",
    "start": "dotenvx run -f .env.prod -- node src/main.mjs"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.54.1",
    "cors": "^2.8.6",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "mysql2": "^3.19.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.0.3",
    "eslint-plugin-es-x": "^9.5.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1"
  }
}
